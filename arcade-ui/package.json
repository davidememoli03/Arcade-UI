{
  "name": "@davide03memoli/arcade-ui",
  "version": "2.7.0",
  "description": "UI component library inspired by 80s arcade games. Retro style, neon palette, pixel animations, built-in SFX — zero runtime dependencies.",
  "keywords": [
    "ui",
    "arcade",
    "retro",
    "css",
    "components",
    "design-system",
    "pixel",
    "neon",
    "audio",
    "web-audio",
    "animation"
  ],
  "homepage": "https://davidememoli03.github.io/Arcade-UI/",
  "repository": {
    "type": "git",
    "url": "https://github.com/davidememoli03/Arcade-UI.git"
  },
  "bugs": {
    "url": "https://github.com/davidememoli03/Arcade-UI/issues"
  },
  "license": "MIT",
  "author": "Davide Memoli",
  "main": "dist/arcade-ui.cjs.js",
  "module": "dist/arcade-ui.es.js",
  "types": "dist/arcade-ui.d.ts",
  "exports": {
    ".": {
      "import": "./dist/arcade-ui.es.js",
      "require": "./dist/arcade-ui.cjs.js"
    },
    "./js": {
      "import": "./dist/arcade-ui.es.js",
      "require": "./dist/arcade-ui.cjs.js"
    },
    "./dist/arcade-ui.css": "./dist/arcade-ui.css",
    "./dist/arcade-ui.min.css": "./dist/arcade-ui.min.css",
    "./tokens/colors": "./src/tokens/colors.css",
    "./tokens/animation": "./src/tokens/animation.css",
    "./tokens/spacing": "./src/tokens/spacing.css",
    "./tokens/typography": "./src/tokens/typography.css",
    "./tokens/tokens.json": "./dist/tokens.json"
  },
  "files": [
    "dist",
    "src/tokens",
    "LICENSE"
  ],
  "sideEffects": [
    "*.css"
  ],
  "private": false,
  "type": "module",
  "scripts": {
    "dev": "storybook dev -p 6006",
    "build:tokens": "style-dictionary build --config style-dictionary.config.js",
    "build": "npm run build:tokens && vite build && npm run minify:css && cp src/arcade-ui.d.ts dist/arcade-ui.d.ts && cp src/tokens/tokens.flat.json dist/tokens.json",
    "build:watch": "vite build --watch",
    "minify:css": "postcss dist/arcade-ui.css --use cssnano -o dist/arcade-ui.min.css",
    "lint": "npm run lint:js && npm run lint:css",
    "lint:js": "eslint src",
    "lint:css": "stylelint src/**/*.css",
    "test": "vitest run",
    "prepublishOnly": "npm run lint && npm test && npm run build",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "peerDependencies": {
    "howler": "^2.0.0"
  },
  "peerDependenciesMeta": {
    "howler": {
      "optional": true
    }
  },
  "devDependencies": {
    "@storybook/html-vite": "^10.3.6",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@vitest/browser": "^4.1.5",
    "@vitest/coverage-v8": "^4.1.5",
    "autoprefixer": "^10.5.0",
    "cssnano": "^7.1.9",
    "eslint": "^10.3.0",
    "howler": "^2.2.4",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.14",
    "postcss-cli": "^11.0.1",
    "storybook": "^10.3.6",
    "style-dictionary": "^5.4.0",
    "stylelint": "^17.10.0",
    "stylelint-config-standard": "^40.0.0",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  }
}